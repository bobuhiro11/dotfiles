{
  "env": {},
  "language": "english",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Write(*)",
      "Edit(*)",
      "Read(*)",
      "Bash(*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(gh pr review:*)",
      "Bash(rm -rf:*)",
      "Bash(git init:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git clone:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Write(.env*)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccusage statusline"
  },
  "skipAutoPermissionPrompt": true
}
